#. Plugin Name of the plugin
msgid "Divi Contact Form Confirmation Email"
msgstr "ایمیل تأیید فرم تماس دیوی"

#. Description of the plugin
msgid "Sends an automatic confirmation email to users after they submit a Divi contact form. Compatible with Divi 4, Divi 5, and the latest WordPress."
msgstr "پس از ارسال فرم تماس دیوی، یک ایمیل تأیید خودکار برای کاربر ارسال می‌کند. سازگار با دیوی ۴، دیوی ۵ و آخرین نسخه وردپرس."

# ── Activation defaults ──────────────────────────────────────────────────────

msgid "We received your message!"
msgstr "پیام شما دریافت شد!"

msgid "Hello {name},\n\nThank you for contacting us. We have received your message and will get back to you as soon as possible.\n\nBest regards,\n{site_name}"
msgstr "سلام {name}،\n\nاز اینکه با ما تماس گرفتید سپاسگزاریم. پیام شما را دریافت کردیم و در اسرع وقت پاسخ خواهیم داد.\n\nبا احترام،\n{site_name}"

# ── Admin menu ───────────────────────────────────────────────────────────────

msgid "Divi Confirmation Email"
msgstr "ایمیل تأیید دیوی"

msgid "Divi Confirmation"
msgstr "تأیید دیوی"

# ── Tabs ─────────────────────────────────────────────────────────────────────

msgid "Email Settings"
msgstr "تنظیمات ایمیل"

msgid "Security"
msgstr "امنیت"

msgid "Logs"
msgstr "گزارش‌ها"

# ── Email settings fields ────────────────────────────────────────────────────

msgid "Email Subject"
msgstr "موضوع ایمیل"

msgid "Email Body"
msgstr "متن ایمیل"

msgid "Placeholders: {name}, {email}, {site_name}, {site_url}, {date}, {time} — and any form field ID wrapped in braces."
msgstr "متغیرها: {name}، {email}، {site_name}، {site_url}، {date}، {time} — و هر شناسه فیلد فرم داخل آکولاد."

msgid "From Name"
msgstr "نام فرستنده"

msgid "From Email Address"
msgstr "آدرس ایمیل فرستنده"

msgid "Save Email Settings"
msgstr "ذخیره تنظیمات ایمیل"

# ── Placeholder reference table ──────────────────────────────────────────────

msgid "Available placeholders"
msgstr "متغیرهای قابل استفاده"

msgid "Placeholder"
msgstr "متغیر"

msgid "Replaced with"
msgstr "جایگزین می‌شود با"

msgid "Submitter's name (falls back to email)"
msgstr "نام فرستنده فرم (در صورت نبود، آدرس ایمیل جایگزین می‌شود)"

msgid "Submitter's email address"
msgstr "آدرس ایمیل فرستنده فرم"

msgid "Your site name"
msgstr "نام وب‌سایت شما"

msgid "Your site URL"
msgstr "آدرس وب‌سایت شما"

msgid "Submission date"
msgstr "تاریخ ارسال فرم"

msgid "Submission time"
msgstr "زمان ارسال فرم"

msgid "Any Divi form field — wrap its ID in braces"
msgstr "هر فیلد فرم دیوی — شناسه آن را داخل آکولاد قرار دهید"

# ── Security settings fields ─────────────────────────────────────────────────

msgid "Enable confirmation emails"
msgstr "فعال‌سازی ایمیل‌های تأیید"

msgid "Uncheck to disable all confirmation emails without deactivating the plugin."
msgstr "برای غیرفعال کردن تمام ایمیل‌های تأیید بدون غیرفعال کردن افزونه، این گزینه را از حالت انتخاب خارج کنید."

msgid "Rate limit (per IP / hour)"
msgstr "محدودیت تعداد ارسال (به ازای هر IP در ساعت)"

msgid "Maximum confirmation emails sent to the same IP address per hour. Set to 0 to disable."
msgstr "حداکثر تعداد ایمیل‌های تأیید ارسال‌شده به همان آدرس IP در هر ساعت. برای غیرفعال کردن، عدد ۰ وارد کنید."

msgid "Blocked email domains"
msgstr "دامنه‌های ایمیل مسدود شده"

msgid "Comma-separated. Submissions from these domains will be silently ignored. Example: tempmail.com, mailinator.com"
msgstr "با کاما جدا کنید. ارسال‌هایی از این دامنه‌ها بدون اطلاع نادیده گرفته می‌شوند. مثال: tempmail.com, mailinator.com"

msgid "Blocked keywords"
msgstr "کلمات کلیدی مسدود شده"

msgid "Comma-separated. If any submitted field contains one of these words, the confirmation email is suppressed. Example: casino, viagra"
msgstr "با کاما جدا کنید. اگر هر فیلد ارسالی حاوی یکی از این کلمات باشد، ایمیل تأیید ارسال نمی‌شود. مثال: casino, viagra"

msgid "Require valid MX record"
msgstr "الزام وجود رکورد MX معتبر"

msgid "Only send if the recipient's domain has a valid DNS MX record. May slow down form submissions on some hosts."
msgstr "ایمیل را فقط در صورت وجود رکورد MX معتبر در DNS دامنه گیرنده ارسال کنید. ممکن است بر روی برخی هاست‌ها ارسال فرم را کند کند."

msgid "Log blocked attempts"
msgstr "ثبت تلاش‌های مسدود شده"

msgid "Write a log entry (status = Blocked) when a submission is suppressed by a security rule."
msgstr "هنگامی که ارسال فرم توسط یک قانون امنیتی متوقف می‌شود، یک رکورد گزارش (وضعیت = مسدود شد) ثبت کنید."

msgid "Save Security Settings"
msgstr "ذخیره تنظیمات امنیتی"

# ── Log table ────────────────────────────────────────────────────────────────

#. translators: %d = number of log entries
msgid "%d log entries total"
msgstr "%d ورودی گزارش در مجموع"

msgid "Delete all log entries? This cannot be undone."
msgstr "آیا می‌خواهید همه ورودی‌های گزارش را حذف کنید؟ این عملیات قابل بازگشت نیست."

msgid "Clear all logs"
msgstr "پاک کردن همه گزارش‌ها"

msgid "Log cleared."
msgstr "گزارش‌ها پاک شدند."

msgid "No emails have been sent yet."
msgstr "هنوز هیچ ایمیلی ارسال نشده است."

msgid "Date / Time"
msgstr "تاریخ / زمان"

msgid "Recipient"
msgstr "گیرنده"

msgid "Subject"
msgstr "موضوع"

msgid "Status"
msgstr "وضعیت"

msgid "Note"
msgstr "یادداشت"

# ── Status labels ────────────────────────────────────────────────────────────

msgid "Sent"
msgstr "ارسال شد"

msgid "Failed"
msgstr "ناموفق"

msgid "Blocked"
msgstr "مسدود شد"

# ── Security block reasons ───────────────────────────────────────────────────

msgid "Plugin disabled"
msgstr "افزونه غیرفعال است"

msgid "Rate limit exceeded"
msgstr "محدودیت تعداد ارسال نقض شد"

msgid "Blocked email domain"
msgstr "دامنه ایمیل مسدود شده"

msgid "Blocked keyword found"
msgstr "کلمه کلیدی مسدود شده یافت شد"

msgid "No MX record for domain"
msgstr "رکورد MX برای این دامنه وجود ندارد"

# ── Misc ─────────────────────────────────────────────────────────────────────

msgid "Not allowed."
msgstr "دسترسی مجاز نیست."

#. translators: 1: plugin version number, 2: HTML link to author website
msgid "Version %1$s &mdash; Developed by %2$s"
msgstr "نسخه %1$s &mdash; توسعه‌یافته توسط %2$s"
