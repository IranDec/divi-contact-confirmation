#. Plugin Name of the plugin
msgid "Divi Contact Form Confirmation Email"
msgstr "Divi Kontaktformular Bestätigungs-E-Mail"

#. Description of the plugin
msgid "Sends an automatic confirmation email to users after they submit a Divi contact form. Compatible with Divi 4, Divi 5, and the latest WordPress."
msgstr "Sendet nach dem Absenden eines Divi-Kontaktformulars automatisch eine Bestätigungs-E-Mail. Kompatibel mit Divi 4, Divi 5 und dem neuesten WordPress."

# ── Activation defaults ──────────────────────────────────────────────────────

msgid "We received your message!"
msgstr "Wir haben Ihre Nachricht erhalten!"

msgid "Hello {name},\n\nThank you for contacting us. We have received your message and will get back to you as soon as possible.\n\nBest regards,\n{site_name}"
msgstr "Hallo {name},\n\nvielen Dank für Ihre Nachricht. Wir haben Ihre Anfrage erhalten und werden uns so schnell wie möglich bei Ihnen melden.\n\nMit freundlichen Grüßen,\n{site_name}"

# ── Admin menu ───────────────────────────────────────────────────────────────

msgid "Divi Confirmation Email"
msgstr "Divi Bestätigungs-E-Mail"

msgid "Divi Confirmation"
msgstr "Divi Bestätigung"

# ── Tabs ─────────────────────────────────────────────────────────────────────

msgid "Email Settings"
msgstr "E-Mail-Einstellungen"

msgid "Security"
msgstr "Sicherheit"

msgid "Logs"
msgstr "Protokolle"

# ── Email settings fields ────────────────────────────────────────────────────

msgid "Email Subject"
msgstr "E-Mail-Betreff"

msgid "Email Body"
msgstr "E-Mail-Text"

msgid "Placeholders: {name}, {email}, {site_name}, {site_url}, {date}, {time} — and any form field ID wrapped in braces."
msgstr "Platzhalter: {name}, {email}, {site_name}, {site_url}, {date}, {time} – sowie jede Formularfeld-ID in geschweiften Klammern."

msgid "From Name"
msgstr "Absendername"

msgid "From Email Address"
msgstr "Absender-E-Mail-Adresse"

msgid "Save Email Settings"
msgstr "E-Mail-Einstellungen speichern"

# ── Placeholder reference table ──────────────────────────────────────────────

msgid "Available placeholders"
msgstr "Verfügbare Platzhalter"

msgid "Placeholder"
msgstr "Platzhalter"

msgid "Replaced with"
msgstr "Ersetzt durch"

msgid "Submitter's name (falls back to email)"
msgstr "Name des Absenders (Fallback: E-Mail-Adresse)"

msgid "Submitter's email address"
msgstr "E-Mail-Adresse des Absenders"

msgid "Your site name"
msgstr "Name Ihrer Website"

msgid "Your site URL"
msgstr "URL Ihrer Website"

msgid "Submission date"
msgstr "Datum der Formularübermittlung"

msgid "Submission time"
msgstr "Uhrzeit der Formularübermittlung"

msgid "Any Divi form field — wrap its ID in braces"
msgstr "Jedes Divi-Formularfeld — die Feld-ID in geschweifte Klammern setzen"

# ── Security settings fields ─────────────────────────────────────────────────

msgid "Enable confirmation emails"
msgstr "Bestätigungs-E-Mails aktivieren"

msgid "Uncheck to disable all confirmation emails without deactivating the plugin."
msgstr "Deaktivieren Sie diese Option, um alle Bestätigungs-E-Mails zu deaktivieren, ohne das Plugin zu deinstallieren."

msgid "Rate limit (per IP / hour)"
msgstr "Ratenlimit (pro IP-Adresse / Stunde)"

msgid "Maximum confirmation emails sent to the same IP address per hour. Set to 0 to disable."
msgstr "Maximale Anzahl von Bestätigungs-E-Mails pro IP-Adresse und Stunde. 0 eingeben, um zu deaktivieren."

msgid "Blocked email domains"
msgstr "Gesperrte E-Mail-Domains"

msgid "Comma-separated. Submissions from these domains will be silently ignored. Example: tempmail.com, mailinator.com"
msgstr "Kommagetrennt. Einsendungen von diesen Domains werden stillschweigend ignoriert. Beispiel: tempmail.com, mailinator.com"

msgid "Blocked keywords"
msgstr "Gesperrte Schlüsselwörter"

msgid "Comma-separated. If any submitted field contains one of these words, the confirmation email is suppressed. Example: casino, viagra"
msgstr "Kommagetrennt. Wenn ein Formularfeld eines dieser Wörter enthält, wird die Bestätigungs-E-Mail unterdrückt. Beispiel: casino, viagra"

msgid "Require valid MX record"
msgstr "Gültigen MX-Eintrag erfordern"

msgid "Only send if the recipient's domain has a valid DNS MX record. May slow down form submissions on some hosts."
msgstr "Nur senden, wenn die Domain des Empfängers einen gültigen DNS-MX-Eintrag besitzt. Kann bei manchen Hostern die Formularübermittlung verlangsamen."

msgid "Log blocked attempts"
msgstr "Gesperrte Versuche protokollieren"

msgid "Write a log entry (status = Blocked) when a submission is suppressed by a security rule."
msgstr "Einen Protokolleintrag (Status = Gesperrt) schreiben, wenn eine Einsendung durch eine Sicherheitsregel unterdrückt wird."

msgid "Save Security Settings"
msgstr "Sicherheitseinstellungen speichern"

# ── Log table ────────────────────────────────────────────────────────────────

