msgid "%d log entries total"
msgstr "%d Protokolleinträge insgesamt"

msgid "Delete all log entries? This cannot be undone."
msgstr "Alle Protokolleinträge löschen? Diese Aktion kann nicht rückgängig gemacht werden."

msgid "Clear all logs"
msgstr "Alle Protokolle löschen"

msgid "Log cleared."
msgstr "Protokoll wurde geleert."

msgid "No emails have been sent yet."
msgstr "Es wurden noch keine E-Mails gesendet."

msgid "Date / Time"
msgstr "Datum / Uhrzeit"

msgid "Recipient"
msgstr "Empfänger"

msgid "Subject"
msgstr "Betreff"

msgid "Status"
msgstr "Status"

msgid "Note"
msgstr "Hinweis"

# ── Status labels ────────────────────────────────────────────────────────────

msgid "Sent"
msgstr "Gesendet"

msgid "Failed"
msgstr "Fehlgeschlagen"

msgid "Blocked"
msgstr "Gesperrt"

# ── Security block reasons ───────────────────────────────────────────────────

msgid "Plugin disabled"
msgstr "Plugin deaktiviert"

msgid "Rate limit exceeded"
msgstr "Ratenlimit überschritten"

msgid "Blocked email domain"
msgstr "Gesperrte E-Mail-Domain"

msgid "Blocked keyword found"
msgstr "Gesperrtes Schlüsselwort gefunden"

msgid "No MX record for domain"
msgstr "Kein MX-Eintrag für diese Domain vorhanden"

